# ─────────────────────────────────────────────────────────────
# Core
# ─────────────────────────────────────────────────────────────
NODE_ENV=development                 # development | production | test
PORT=5000                            # HTTP port the API listens on
API_PREFIX=/api                      # Base path for all versioned routes
CLIENT_URL=http://localhost:5173     # Frontend origin (used in email links)

# ─────────────────────────────────────────────────────────────
# Database (required)
# ─────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/mern_starter

# ─────────────────────────────────────────────────────────────
# JWT (required) — generate with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_to_a_32_char_min_random_secret_00
JWT_REFRESH_SECRET=change_me_to_a_DIFFERENT_32_char_secret_00
JWT_ACCESS_EXPIRES_IN=15m            # short-lived access token
JWT_REFRESH_EXPIRES_IN=7d            # long-lived refresh token

# ─────────────────────────────────────────────────────────────
# Cookies (required)
# ─────────────────────────────────────────────────────────────
COOKIE_SECRET=change_me_min_16_chars # signs the httpOnly refresh cookie
COOKIE_SECURE=false                  # true in production (HTTPS only)

# ─────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173   # comma-separated allowlist

# ─────────────────────────────────────────────────────────────
# Mail (optional) — omit to log emails to console instead of sending
# ─────────────────────────────────────────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=No Reply <noreply@example.com>

# ─────────────────────────────────────────────────────────────
# Optional infrastructure — features degrade gracefully when unset
# ─────────────────────────────────────────────────────────────
REDIS_URL=                           # e.g. redis://localhost:6379 — enables Redis cache
CLOUDINARY_URL=                      # e.g. cloudinary://key:secret@cloud — enables Cloudinary uploads
ENABLE_SOCKET=false                  # true to enable Socket.io
ENABLE_QUEUE=false                   # true (with REDIS_URL) to enable BullMQ jobs

# ─────────────────────────────────────────────────────────────
# Rate limiting & logging
# ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000          # 15 minutes
RATE_LIMIT_MAX=100                   # requests per window per IP
LOG_LEVEL=info                       # error | warn | info | http | debug
