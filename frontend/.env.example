# API base URL the frontend calls. In dev, Vite proxies /api to the backend,
# so the default relative path works with zero config.
VITE_API_URL=/api/v1
VITE_APP_NAME=Nactor

# Dev-only: backend URL for Vite's /api proxy (see vite.config.js).
VITE_PROXY_BASE_URL=http://localhost:4040

# Socket.io server origin for realtime (live task updates + online presence).
# Dev: defaults to VITE_PROXY_BASE_URL. Prod: set to your persistent backend
# host — Socket.io needs a long-lived server and will NOT run on Vercel
# serverless. Leave blank to use the same origin.
VITE_SOCKET_URL=
